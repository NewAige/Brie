{{/*
  Brie sign-in re-skin — injected at the end of Gitea's <head> on every page.

  WHY: The OAuth2 flow (backend/app/routers/auth.py) sends the browser to
  Gitea's own login page to enter the password, so the app never sees it
  (CLAUDE.md). That page is the only spot where "Gitea" branding shows to
  staff. This makes it look like the app's Brie login card (frontend/src/
  pages/Login.jsx) — with NO change to auth logic, flow, or security.

  HOW: link the Brie stylesheet (always — it is scoped to the sign-in page so
  it is inert elsewhere), then a tiny inline script that runs ONLY on the
  sign-in route. It tags <body class="brie-auth">, drops the Brie logo +
  wordmark above the form, and a reassurance line below it. Plain DOM only —
  no network calls, consistent with the app's no-external-calls rule.

  The logo SVG is copied from frontend/src/components/Logo.jsx (the Brie clock
  mark). Keep the two in sync if the mark changes.
*/}}
<link rel="stylesheet" href="{{AssetUrlPrefix}}/css/brie.css">
<script>
(function () {
  // Match Gitea's sign-in routes only: /user/login and the OAuth authorize
  // page render the same signin template. Everything else keeps Gitea's look.
  var p = window.location.pathname;
  if (!/^\/user\/login\b/.test(p) && !/^\/login\/oauth\/authorize\b/.test(p)) return;

  var LOGO = '<svg viewBox="0 0 100 100" width="72" height="72" role="img" aria-label="Brie">'
    + '<circle cx="50" cy="50" r="40" fill="#006F51"/>'
    + '<line x1="50" y1="50" x2="42" y2="35" stroke="#F5F7F8" stroke-width="6" stroke-linecap="round"/>'
    + '<line x1="50" y1="50" x2="63.5" y2="26.5" stroke="#F5F7F8" stroke-width="6" stroke-linecap="round"/>'
    + '<line x1="50" y1="50" x2="36.5" y2="73.5" stroke="#F5F7F8" stroke-width="2.4" stroke-linecap="round"/>'
    + '<circle cx="36.5" cy="73.5" r="3.2" fill="#F5F7F8"/>'
    + '<circle cx="50" cy="50" r="5.5" fill="#F5F7F8"/>'
    + '<circle cx="50" cy="50" r="2.1" fill="#20333F"/>'
    + '</svg>';

  function decorate() {
    document.body.classList.add('brie-auth');

    var form = document.querySelector('.page-content.user.signin form.ui.form');
    if (!form) return;
    var column = form.closest('.column') || form.parentNode;

    // Brand block above the form (logo + BRIE wordmark + PROMPT LIBRARY).
    if (column && !column.querySelector('.brie-brand')) {
      var brand = document.createElement('div');
      brand.className = 'brie-brand';
      brand.innerHTML = LOGO
        + '<div>'
        + '<div class="brie-brand-name">Brie</div>'
        + '<div class="brie-brand-tagline">Prompt Library</div>'
        + '</div>';
      column.insertBefore(brand, column.firstChild);

      var sub = document.createElement('p');
      sub.className = 'brie-subhead';
      sub.textContent = 'Sign in with your bank network account to continue.';
      brand.insertAdjacentElement('afterend', sub);
    }

    // Reassurance line below the form.
    if (column && !column.querySelector('.brie-footnote')) {
      var note = document.createElement('p');
      note.className = 'brie-footnote';
      note.textContent = 'You are signing in through the bank’s internal directory. '
        + 'The Prompt Library never sees your password.';
      form.insertAdjacentElement('afterend', note);
    }

    // Give the page a Brie title instead of "Sign In - Gitea".
    document.title = 'Sign in — Brie Prompt Library';
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', decorate);
  } else {
    decorate();
  }
})();
</script>
