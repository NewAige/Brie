# Copy to .env and fill in. The seed script (scripts/seed.py) does this for you in dev.

# Gitea URL as the user's BROWSER reaches it (OAuth authorize redirect goes here).
GITEA_PUBLIC_URL=http://localhost:3000

# Gitea URL as the BACKEND container reaches it (token exchange + API calls).
GITEA_INTERNAL_URL=http://gitea:3000

# This app's URL as the user's browser reaches it. The OAuth redirect_uri is
# derived from this: ${APP_PUBLIC_URL}/auth/callback — it must EXACTLY match
# the redirect URI registered on the OAuth application in Gitea.
APP_PUBLIC_URL=http://localhost:8080

# OAuth2 application credentials from Gitea (confidential client).
# The client secret is shown ONCE at creation — store it here, never in code.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Random secret for session bookkeeping. Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# The Gitea org/user and repo that holds the prompt markdown files.
REPO_OWNER=bank
REPO_NAME=prompt-library

# Set true in production (HTTPS). Marks the session cookie Secure.
COOKIE_SECURE=false
